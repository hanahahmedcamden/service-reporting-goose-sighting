{% set bodyClasses = ((bodyClasses or "") + " govuk-frontend-supported") | trim %}

{% extends "template.njk" %}

{% block pageTitle %}
  {% if pageTitle %}{{ pageTitle }} - {% endif %}{{ serviceName }} - Camden Council
{% endblock %}

{% block head %}
  <link rel="stylesheet" href="/stylesheets/lbcamden-frontend-1.0.7.min.css">
  <link rel="stylesheet" href="/stylesheets/application.css">
{% endblock %}

{% block header %}
  {{ LBCamdenHeader({
    homepageUrl: "/",
    search: false,
    siteNavigation: {
      title: serviceName,
      homepageUrl: serviceHomeUrl,
      search: false
    },
    phaseBanner: {
      tag: { text: "Prototype" },
      html: "This is not a live service."
    }
  }) }}
{% endblock %}

{% block footer %}
  {{ LBCamdenFooter({
    navigationUtility: [
      { href: "#", text: "Freedom of Information (FOI) requests" },
      { href: "#", text: "Data protection and privacy" },
      { href: "#", text: "Accessibility statement" },
      { href: "#", text: "Cookies" }
    ]
  }) }}
{% endblock %}

{% block bodyEnd %}
  <script src="/javascripts/lbcamden-frontend-1.0.7.min.js"></script>
{% endblock %}
