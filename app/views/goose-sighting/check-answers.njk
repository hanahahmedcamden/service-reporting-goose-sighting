{% extends "layouts/main.njk" %}
{% from "components/button/macro.njk" import LBCamdenButton %}

{% set pageTitle = "Check your answers" %}

{% block beforeContent %}
  <div class="govuk-width-container">
    <a href="/goose-sighting/date" class="govuk-back-link">Back</a>
  </div>
{% endblock %}

{% block content %}
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">Check your answers</h1>

        <dl class="govuk-summary-list">
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Do you like geese?</dt>
            <dd class="govuk-summary-list__value">{{ "Yes" if data.likesGeese == "yes" else "No" }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="/goose-sighting/like-geese">Change<span class="govuk-visually-hidden"> whether you like geese</span></a>
            </dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Type of goose</dt>
            <dd class="govuk-summary-list__value">{{ data.gooseType }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="/goose-sighting/type">Change<span class="govuk-visually-hidden"> type of goose</span></a>
            </dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Date seen</dt>
            <dd class="govuk-summary-list__value">{{ data.gooseSeenDay }} {{ data.gooseSeenMonth }} {{ data.gooseSeenYear }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="/goose-sighting/date">Change<span class="govuk-visually-hidden"> date seen</span></a>
            </dd>
          </div>
        </dl>

        <form action="/goose-sighting/check-answers" method="post">
          {{ LBCamdenButton({
            text: "Accept and send",
            preventDoubleClick: true
          }) }}
        </form>
      </div>
    </div>
  </div>
{% endblock %}
