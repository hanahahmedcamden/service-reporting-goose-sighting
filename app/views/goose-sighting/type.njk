{% extends "layouts/main.njk" %}
{% from "macros/forms.njk" import errorSummary, textInput %}
{% from "components/button/macro.njk" import LBCamdenButton %}

{% set pageTitle = "What type of goose did you see?" %}

{% block beforeContent %}
  <div class="govuk-width-container">
    <a href="/goose-sighting/like-geese" class="govuk-back-link">Back</a>
  </div>
{% endblock %}

{% block content %}
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        {{ errorSummary(errorList) }}

        <form action="/goose-sighting/type" method="post" novalidate>
          <h1 class="govuk-heading-xl">What type of goose did you see?</h1>

          {{ textInput({
            name: "gooseType",
            label: "Type of goose",
            classes: "govuk-input--width-20",
            value: data.gooseType,
            error: errors.gooseType
          }) }}

          <div class="govuk-button-group">
            {{ LBCamdenButton({
              text: "Continue",
              preventDoubleClick: true
            }) }}
          </div>
        </form>
      </div>
    </div>
  </div>
{% endblock %}
